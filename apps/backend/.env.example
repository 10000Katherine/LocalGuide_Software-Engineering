SERVER_PORT=8080

# Use strong random value in real environments (at least 32 bytes)
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-bytes
JWT_ISSUER=localguide
JWT_ACCESS_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=2592000

# Default local database is in-memory H2. Uncomment for MySQL.
# DB_URL=jdbc:mysql://localhost:3306/localguide
# DB_USERNAME=root
# DB_PASSWORD=your-password
# DB_DRIVER=com.mysql.cj.jdbc.Driver
